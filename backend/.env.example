# environment variables used by backend

# Postgres
DATABASE_URL=
PGSSL=false

# Redis (optional)
REDIS_URL=

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=30
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_PER_MIN=2

# M-Pesa (Daraja) credentials
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# SMTP for emails (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AI provider (optional)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_API_BASE=
AI_MAX_PROMPT_CHARS=8000
DEFAULT_AI_MONTHLY_TOKENS=100000

# Strategy call admin email (where booking notifications go)
STRATEGY_ADMIN_EMAIL=
STRATEGY_FROM_EMAIL=

# Frontend allowed origin
FRONTEND_ORIGIN=http://localhost:3000
