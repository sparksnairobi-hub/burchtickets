# Server
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-string

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/burchtickets
# Set to "true" for hosted Postgres (Neon, Supabase, RDS...). Leave unset/false for local dev.
PGSSL=false

# Redis (optional — only needed for async confirmation emails via BullMQ).
# Leave both unset to run without Redis: checkout and payments still work,
# buyers can still download their PDF ticket, confirmation emails are just skipped.
REDIS_HOST=
REDIS_PORT=6379
# Alternative to REDIS_HOST/PORT — a full redis:// or rediss:// URL (e.g. from Upstash/Railway).
REDIS_URL=

# M-Pesa Daraja
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-public-domain.com/api/payments/webhook/mpesa
MPESA_WEBHOOK_SECRET=change-this-shared-secret

# Pesapal (card / mobile money hosted checkout — alternative to M-Pesa STK Push)
# Get consumer key/secret from https://developer.pesapal.com (sandbox) or your
# merchant dashboard (live). Set PESAPAL_ENV=live only once you have live keys.
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
# Where Pesapal sends server-to-server payment notifications (IPN). Must be
# publicly reachable. Register it once with: node src/scripts/registerPesapalIpn.js
PESAPAL_IPN_URL=https://your-public-domain.com/api/payments/webhook/pesapal
# Printed by registerPesapalIpn.js after registration — paste it here.
PESAPAL_IPN_ID=
# Where Pesapal redirects the buyer's browser back to after they pay.
# The frontend's pesapal-return page lives at frontend/index.html?pesapal-return
PESAPAL_CALLBACK_URL=https://your-frontend-domain.com/?pesapal-return=1

# Event discovery — "What's happening in Nairobi" widget (all optional).
# Only Ticketmaster and PredictHQ have real public city-search APIs; the
# rest are documented no-ops or narrower than a full discovery feed.
# See backend/src/services/eventAggregator.js for details on each one.
TICKETMASTER_API_KEY=
PREDICTHQ_API_KEY=
# Bandsintown is artist-scoped only — set an app_id (granted per-artist by
# Bandsintown) plus a comma-separated watchlist of artist names to track.
BANDSINTOWN_APP_ID=
BANDSINTOWN_ARTISTS=

# SMTP (confirmation emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
MAIL_FROM="BurchTickets <hello@burchtickets.com>"
